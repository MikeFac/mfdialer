# Recommended: use a Telnyx WebRTC JWT/login token.
TELNYX_LOGIN_TOKEN=

# Optional fallback: SIP/WebRTC credential username and password.
# These are still sent to the browser at runtime because the Telnyx SDK
# authenticates from the browser. Prefer TELNYX_LOGIN_TOKEN where possible.
TELNYX_SIP_USERNAME=
TELNYX_SIP_PASSWORD=

# Optional outbound caller ID, usually a Telnyx number in E.164 format.
TELNYX_CALLER_NUMBER=

# Server port.
PORT=3400
HOST=127.0.0.1

# Clerk auth.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
DEFAULT_WORKSPACE_OWNER_EMAIL=michaelfackerell@gmail.com

# Prisma SQLite database.
DATABASE_URL=file:./dev.db
